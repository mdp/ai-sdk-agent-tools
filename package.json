{
  "name": "ai-sdk-tools-file-editing",
  "version": "1.0.0",
  "description": "Generic file editing tools for Vercel AI SDK v6 agents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-sdk",
    "vercel",
    "ai",
    "tools",
    "file-editing",
    "agents",
    "llm"
  ],
  "author": "",
