  "repository": {
    "type": "git",
    "url": "https://github.com/mdp/ai-sdk-tools-file-editing"
  },
  "bugs": {
    "url": "https://github.com/mdp/ai-sdk-tools-file-editing/issues"
  },
  "homepage": "https://github.com/mdp/ai-sdk-tools-file-editing#readme",
  "peerDependencies": {
    "ai": "^6.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ai": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "zod": "^3.22.0"
  }
}
